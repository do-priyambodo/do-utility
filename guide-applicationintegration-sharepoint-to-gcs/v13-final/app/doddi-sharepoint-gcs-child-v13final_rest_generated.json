{
  "triggerConfigs": [
    {
      "label": "API Trigger",
      "triggerType": "API",
      "triggerNumber": "1",
      "triggerId": "api_trigger/doddi-sharepoint-gcs-child-v13final-trigger",
      "startTasks": [
        {
          "taskId": "6"
        }
      ],
      "properties": {
        "Trigger name": "doddi-sharepoint-gcs-child-v13final-trigger"
      },
      "inputVariables": {
        "names": [
          "INPUT_Loop_Item"
        ]
      },
      "outputVariables": {
        "names": [
          "`Child_Sync_Success`",
          "`Child_Error_Message`"
        ]
      }
    }
  ],
  "taskConfigs": [
    {
      "task": "JsonnetMapperTask",
      "parameters": {
        "template": {
          "key": "template",
          "value": {
            "stringValue": "local item = std.extVar(\"INPUT_Loop_Item\");\n{\n  \"`Is_Page_Flow`\": if \"IsPage\" in item then item[\"IsPage\"] == true else false\n}"
          }
        }
      },
      "nextTasks": [
        {
          "condition": "$`Is_Page_Flow`$ = false",
          "taskId": "1"
        },
        {
          "condition": "$`Is_Page_Flow`$ = true",
          "taskId": "5"
        }
      ],
      "displayName": "Check Page Routing",
      "taskId": "6"
    },
    {
      "task": "JsonnetMapperTask",
      "parameters": {
        "template": {
          "key": "template",
          "value": {
            "stringValue": "local inputs = {\n  \"`CONFIG_SharePoint_Hostname`\": std.extVar(\"`CONFIG_SharePoint_Hostname`\"),\n  \"INPUT_Loop_Item\": std.extVar(\"INPUT_Loop_Item\")\n};\nlocal fileObject = inputs[\"INPUT_Loop_Item\"];\nlocal rawUrl = fileObject[\"Url\"];\nlocal sharepointHost = inputs[\"`CONFIG_SharePoint_Hostname`\"];\nlocal urlWithPort = std.strReplace(rawUrl, \"https://\" + sharepointHost + \"/\", \"https://\" + sharepointHost + \":443/\");\n{\n  \"`Task_2_connectorInputPayload`\": {\n    \"Library\": if std.objectHas(fileObject, \"LibraryName\") then fileObject[\"LibraryName\"] else \"Shared Documents\",\n    \"RemoteFile\": urlWithPort,\n    \"HasBytes\": true\n  }\n}"
          }
        }
      },
      "nextTasks": [
        {
          "taskId": "2"
        }
      ],
      "displayName": "Download file request mapping",
      "taskId": "1"
    },
    {
      "task": "GenericConnectorTask",
      "parameters": {
        "connectionName": {
          "key": "connectionName",
          "value": {
            "stringValue": "projects/work-mylab-machinelearning/locations/asia-southeast1/connections/doddi-connection-sharepoint-sync"
          }
        },
        "connectionVersion": {
          "key": "connectionVersion",
          "value": {
            "stringValue": "projects/{projectId}/locations/global/providers/microsoft/connectors/sharepoint/versions/2"
          }
        },
        "operation": {
          "key": "operation",
          "value": {
            "stringValue": "EXECUTE_ACTION"
          }
        },
        "actionName": {
          "key": "actionName",
          "value": {
            "stringValue": "DownloadDocument"
          }
        },
        "authOverrideEnabled": {
          "key": "authOverrideEnabled",
          "value": {
            "booleanValue": false
          }
        },
        "connectorInputPayload": {
          "key": "connectorInputPayload",
          "value": {
            "stringValue": "$`Task_2_connectorInputPayload`$"
          }
        },
        "connectorOutputPayload": {
          "key": "connectorOutputPayload",
          "value": {
            "stringValue": "$`Task_2_connectorOutputPayload`$"
          }
        }
      },
      "nextTasks": [
        {
          "taskId": "3"
        }
      ],
      "errorCatcherId": "ErrorCatcher_1",
      "failurePolicy": {
        "retryStrategy": "EXPONENTIAL_BACKOFF",
        "maxRetries": 3,
        "intervalTime": "1970-01-01T00:00:03Z"
      },
      "displayName": "Download file sharepoint",
      "taskId": "2"
    },
    {
      "task": "JsonnetMapperTask",
      "parameters": {
        "template": {
          "key": "template",
          "value": {
            "stringValue": "local inputs = {\n  \"`CONFIG_GCS_Bucket`\": std.extVar(\"`CONFIG_GCS_Bucket`\"),\n  \"INPUT_Loop_Item\": std.extVar(\"INPUT_Loop_Item\"),\n  \"`Task_2_connectorOutputPayload`\": std.extVar(\"`Task_2_connectorOutputPayload`\")\n};\nlocal fileObject = inputs[\"INPUT_Loop_Item\"];\nlocal fileName = fileObject[\"Name\"];\nlocal relativePath = fileObject[\"RelativePath\"];\nlocal objectName = if std.objectHas(fileObject, \"_filename\") then fileObject[\"_filename\"] else if std.objectHas(fileObject, \"RelativePath\") && fileObject[\"RelativePath\"] != \"\" then (if std.startsWith(fileObject[\"RelativePath\"], \"files/\") then std.substr(fileObject[\"RelativePath\"], 6, std.length(fileObject[\"RelativePath\"]) - 6) else fileObject[\"RelativePath\"]) else fileName;\nlocal isPdf = std.endsWith(fileName, \".pdf\") || std.endsWith(fileName, \".PDF\");\nlocal isDocx = std.endsWith(fileName, \".docx\") || std.endsWith(fileName, \".DOCX\");\nlocal isDoc = std.endsWith(fileName, \".doc\") || std.endsWith(fileName, \".DOC\");\nlocal isPptx = std.endsWith(fileName, \".pptx\") || std.endsWith(fileName, \".PPTX\");\nlocal isPpt = std.endsWith(fileName, \".ppt\") || std.endsWith(fileName, \".PPT\");\nlocal isXlsx = std.endsWith(fileName, \".xlsx\") || std.endsWith(fileName, \".XLSX\");\nlocal isXls = std.endsWith(fileName, \".xls\") || std.endsWith(fileName, \".XLS\");\nlocal isTxt = std.endsWith(fileName, \".txt\") || std.endsWith(fileName, \".TXT\");\nlocal isHtml = std.endsWith(fileName, \".html\") || std.endsWith(fileName, \".HTML\") || std.endsWith(fileName, \".htm\") || std.endsWith(fileName, \".aspx\");\nlocal contentType = if isPdf then \"application/pdf\" else if isDocx then \"application/vnd.openxmlformats-officedocument.wordprocessingml.document\" else if isDoc then \"application/msword\" else if isPptx then \"application/vnd.openxmlformats-officedocument.presentationml.presentation\" else if isPpt then \"application/vnd.ms-powerpoint\" else if isXlsx then \"application/vnd.openxmlformats-officedocument.spreadsheetml.sheet\" else if isXls then \"application/vnd.ms-excel\" else if isTxt then \"text/plain\" else if isHtml then \"text/html\" else \"application/octet-stream\";\nlocal contentBytes = inputs[\"`Task_2_connectorOutputPayload`\"][0][\"ContentBytes\"];\n{\n  \"`Task_4_connectorInputPayload`\": {\n    \"Bucket\": inputs[\"`CONFIG_GCS_Bucket`\"],\n    \"ContentBytes\": contentBytes,\n    \"Content\": contentBytes,\n    \"ObjectName\": objectName,\n    \"FolderPath\": \"files\",\n    \"ContentType\": contentType,\n    \"HasBytes\": true\n  }\n}"
          }
        }
      },
      "nextTasks": [
        {
          "taskId": "4"
        }
      ],
      "displayName": "Upload file request mapping",
      "taskId": "3"
    },
    {
      "task": "JsonnetMapperTask",
      "parameters": {
        "template": {
          "key": "template",
          "value": {
            "stringValue": "local inputs = {\n  \"`CONFIG_GCS_Bucket`\": std.extVar(\"`CONFIG_GCS_Bucket`\"),\n  \"INPUT_Loop_Item\": std.extVar(\"INPUT_Loop_Item\")\n};\nlocal pageObject = inputs[\"INPUT_Loop_Item\"];\nlocal fileName = pageObject[\"Name\"];\nlocal objectName = if std.objectHas(pageObject, \"_filename\") then pageObject[\"_filename\"] else if std.objectHas(pageObject, \"RelativePath\") && std.startsWith(pageObject[\"RelativePath\"], \"pages/\") then std.substr(pageObject[\"RelativePath\"], 6, std.length(pageObject[\"RelativePath\"]) - 6) else fileName;\nlocal pdfBase64 = pageObject[\"VirtualContent\"];\n{\n  \"`Task_7_connectorInputPayload`\": {\n    \"Bucket\": inputs[\"`CONFIG_GCS_Bucket`\"],\n    \"ContentBytes\": pdfBase64,\n    \"Content\": pdfBase64,\n    \"ObjectName\": objectName,\n    \"FolderPath\": \"pages\",\n    \"ContentType\": \"application/pdf\",\n    \"HasBytes\": true\n  }\n}"
          }
        }
      },
      "nextTasks": [
        {
          "taskId": "7"
        }
      ],
      "displayName": "Upload page request mapping",
      "taskId": "5"
    },
