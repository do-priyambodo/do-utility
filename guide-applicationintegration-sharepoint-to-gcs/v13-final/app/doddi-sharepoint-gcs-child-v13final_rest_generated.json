    {
      "task": "GenericConnectorTask",
      "parameters": {
        "connectionName": {
          "key": "connectionName",
          "value": {
            "stringValue": "projects/work-mylab-machinelearning/locations/asia-southeast1/connections/doddi-connection-gcs-sync"
          }
