{
  "triggerConfigs": [
    {
      "label": "API Trigger",
      "triggerType": "API",
      "triggerNumber": "1",
      "triggerId": "api_trigger/yourorg-sharepoint-gcs-child-trigger",
      "startTasks": [
        {
          "taskId": "6"
        }
      ],
      "properties": {
        "Trigger name": "yourorg-sharepoint-gcs-child-trigger"
      },
      "inputVariables": {
        "names": [
          "INPUT_Loop_Item"
        ]
      },
      "outputVariables": {}
    }
  ],
  "taskConfigs": [
    {
      "task": "JsonnetMapperTask",
      "parameters": {
        "template": {
          "key": "template",
          "value": {
            "stringValue": "local item = std.extVar(\"INPUT_Loop_Item\");\n{\n  \"`Is_Page_Flow`\": if \"IsPage\" in item then item[\"IsPage\"] == true else false\n}"
          }
        }
      },
      "nextTasks": [
        {
          "condition": "$`Is_Page_Flow`$ = false",
          "taskId": "1"
        },
        {
          "condition": "$`Is_Page_Flow`$ = true",
          "taskId": "5"
        }
      ],
      "displayName": "Check Page Routing",
      "taskId": "6"
    },
    {
      "task": "JsonnetMapperTask",
      "parameters": {
        "template": {
          "key": "template",
          "value": {
            "stringValue": "local inputs = {\n  \"`CONFIG_SharePoint_Hostname`\": std.extVar(\"`CONFIG_SharePoint_Hostname`\"),\n  \"INPUT_Loop_Item\": std.extVar(\"INPUT_Loop_Item\")\n};\nlocal fileObject = inputs[\"INPUT_Loop_Item\"];\nlocal rawUrl = fileObject[\"Url\"];\nlocal sharepointHost = inputs[\"`CONFIG_SharePoint_Hostname`\"];\nlocal urlWithPort = std.strReplace(rawUrl, \"https://\" + sharepointHost + \"/\", \"https://\" + sharepointHost + \":443/\");\n{\n  \"`Task_2_connectorInputPayload`\": {\n    \"Library\": \"Shared Documents\",\n    \"RemoteFile\": urlWithPort,\n    \"HasBytes\": true\n  }\n}"
          }
        }
      },
      "nextTasks": [
        {
          "taskId": "2"
        }
      ],
      "displayName": "Download file request mapping",
      "taskId": "1"
    },
    {
      "task": "GenericConnectorTask",
      "parameters": {
        "connectionName": {
          "key": "connectionName",
          "value": {
            "stringValue": "projects/work-mylab-machinelearning/locations/asia-southeast1/connections/yourorg-connection-sharepoint-sync"
          }
        },
        "connectionVersion": {
          "key": "connectionVersion",
          "value": {
            "stringValue": "projects/{projectId}/locations/global/providers/microsoft/connectors/sharepoint/versions/2"
          }
        },
        "operation": {
          "key": "operation",
          "value": {
            "stringValue": "EXECUTE_ACTION"
          }
        },
        "actionName": {
          "key": "actionName",
          "value": {
            "stringValue": "DownloadDocument"
          }
        },
        "authOverrideEnabled": {
          "key": "authOverrideEnabled",
          "value": {
            "booleanValue": false
          }
        },
        "connectorInputPayload": {
          "key": "connectorInputPayload",
          "value": {
            "stringValue": "$`Task_2_connectorInputPayload`$"
          }
        },
        "connectorOutputPayload": {
          "key": "connectorOutputPayload",
          "value": {
            "stringValue": "$`Task_2_connectorOutputPayload`$"
          }
        }
      },
      "nextTasks": [
        {
          "taskId": "3"
        }
      ],
      "displayName": "Download file sharepoint",
      "taskId": "2"
    },
    {
      "task": "JsonnetMapperTask",
      "parameters": {
        "template": {
          "key": "template",
          "value": {
            "stringValue": "local inputs = {\n  \"`CONFIG_GCS_Bucket`\": std.extVar(\"`CONFIG_GCS_Bucket`\"),\n  \"INPUT_Loop_Item\": std.extVar(\"INPUT_Loop_Item\"),\n  \"`Task_2_connectorOutputPayload`\": std.extVar(\"`Task_2_connectorOutputPayload`\")\n};\nlocal fileObject = inputs[\"INPUT_Loop_Item\"];\nlocal fileName = fileObject[\"Name\"];\nlocal relativePath = fileObject[\"RelativePath\"];\nlocal folderPath = if std.endsWith(relativePath, \"/\" + fileName) then std.substr(relativePath, 0, std.length(relativePath) - std.length(\"/\" + fileName)) else if std.endsWith(relativePath, fileName) && relativePath != fileName then std.substr(relativePath, 0, std.length(relativePath) - std.length(fileName)) else \"\";\nlocal isPdf = std.endsWith(fileName, \".pdf\") || std.endsWith(fileName, \".PDF\");\nlocal isDocx = std.endsWith(fileName, \".docx\") || std.endsWith(fileName, \".DOCX\");\nlocal isDoc = std.endsWith(fileName, \".doc\") || std.endsWith(fileName, \".DOC\");\nlocal isPptx = std.endsWith(fileName, \".pptx\") || std.endsWith(fileName, \".PPTX\");\nlocal isPpt = std.endsWith(fileName, \".ppt\") || std.endsWith(fileName, \".PPT\");\nlocal isXlsx = std.endsWith(fileName, \".xlsx\") || std.endsWith(fileName, \".XLSX\");\nlocal isXls = std.endsWith(fileName, \".xls\") || std.endsWith(fileName, \".XLS\");\nlocal isTxt = std.endsWith(fileName, \".txt\") || std.endsWith(fileName, \".TXT\");\nlocal isHtml = std.endsWith(fileName, \".html\") || std.endsWith(fileName, \".HTML\") || std.endsWith(fileName, \".htm\") || std.endsWith(fileName, \".aspx\");\nlocal contentType = if isPdf then \"application/pdf\" else if isDocx then \"application/vnd.openxmlformats-officedocument.wordprocessingml.document\" else if isDoc then \"application/msword\" else if isPptx then \"application/vnd.openxmlformats-officedocument.presentationml.presentation\" else if isPpt then \"application/vnd.ms-powerpoint\" else if isXlsx then \"application/vnd.openxmlformats-officedocument.spreadsheetml.sheet\" else if isXls then \"application/vnd.ms-excel\" else if isTxt then \"text/plain\" else if isHtml then \"text/html\" else \"application/octet-stream\";\n{\n  \"`Task_4_connectorInputPayload`\": {\n    \"Bucket\": inputs[\"`CONFIG_GCS_Bucket`\"],\n    \"ContentBytes\": inputs[\"`Task_2_connectorOutputPayload`\"][0][\"ContentBytes\"],\n    \"ObjectName\": fileName,\n    [if folderPath != \"\" then \"FolderPath\"]: \"files/\" + folderPath,\n    [if folderPath == \"\" then \"FolderPath\"]: \"files\",\n    \"ContentType\": contentType,\n    \"HasBytes\": true\n  }\n}"
          }
        }
      },
      "nextTasks": [
        {
          "taskId": "4"
        }
      ],
      "displayName": "Upload file request mapping",
      "taskId": "3"
    },
    {
      "task": "JsonnetMapperTask",
      "parameters": {
        "template": {
          "key": "template",
          "value": {
            "stringValue": "local inputs = {\n  \"`CONFIG_GCS_Bucket`\": std.extVar(\"`CONFIG_GCS_Bucket`\"),\n  \"INPUT_Loop_Item\": std.extVar(\"INPUT_Loop_Item\")\n};\nlocal pageObject = inputs[\"INPUT_Loop_Item\"];\nlocal fileName = pageObject[\"Name\"];\nlocal pdfBase64 = pageObject[\"VirtualContent\"];\n{\n  \"`Task_7_connectorInputPayload`\": {\n    \"Bucket\": inputs[\"`CONFIG_GCS_Bucket`\"],\n    \"ContentBytes\": pdfBase64,\n    \"ObjectName\": fileName,\n    \"FolderPath\": \"pages\",\n    \"ContentType\": \"application/pdf\",\n    \"HasBytes\": true\n  }\n}"
          }
        }
      },
      "nextTasks": [
        {
          "taskId": "7"
        }
      ],
